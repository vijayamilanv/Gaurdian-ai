# Guardian AI — Backend Environment Variables
# Copy this file to .env and fill in the values.

# ── Database (Neon PostgreSQL) ────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require&channel_binding=require"

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET="change-me-to-a-long-random-string"

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0

# ── AI Service ────────────────────────────────────────────────────────────────
AI_SERVICE_URL=http://localhost:8000

# ── Gemini API ────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here

# ── Cloudflare R2 ─────────────────────────────────────────────────────────────
# Get from dash.cloudflare.com > R2 > Manage R2 API Tokens
R2_ENDPOINT=
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# ── Gmail OAuth2 ──────────────────────────────────────────────────────────────
# Get from console.cloud.google.com > APIs & Services > Gmail API
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/gmail/callback
FRONTEND_URL=http://localhost:5173

# ── Encryption Keys (AES-256-GCM) ─────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
GMAIL_ENCRYPTION_KEY=
HEALTH_ENCRYPTION_KEY=
